{
  "_comment": "MMTH Analyzer 配置文件 - Docker 独立部署",
  "_accounts_comment": "accounts 为 mmth 账号名（需与 mmth 下拉菜单显示一致）",
  "_log_path_comment": "log_path 为目录，ETL 会遍历目录下所有 .log 文件",
  "port": "5391",
  "scrape_interval": "6h",
  "mmth_servers": [
    {
      "name": "server1",
      "base_url": "http://host.docker.internal:5290",
      "accounts": ["account1", "account2"],
      "log_path": "/app/mmth-logs"
    }
  ],
  "data_dir": "/app/data",
  "etl_binary_path": "/app/mmth-etl/mmth_etl",
  "etl_output_dir": "/app/data/etl"
}
