{
  "_comment": "MMTH Analyzer 配置文件 - 修改后重启服务生效",
  "port": "5391",
  "scrape_interval": "6h",
  "mmth_servers": [
    {
      "_comment": "服务器1配置",
      "name": "server1",
      "base_url": "http://YOUR_SERVER_IP:PORT",
      "accounts": ["account1", "account2"],
      "log_path": "./data/logs/server1.log"
    },
    {
      "_comment": "服务器2配置（可选）",
      "name": "server2",
      "base_url": "http://YOUR_SERVER_IP:PORT",
      "accounts": ["account3"],
      "log_path": "./data/logs/server2.log"
    }
  ],
  "_data_dir": "./data",
  "_etl_binary_path": "./mmth-etl/mmth_etl.exe",
  "_etl_output_dir": "./data/etl"
}
