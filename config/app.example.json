{
  "_comment": "MMTH Analyzer 配置文件 - 修改后重启服务生效",
  "_accounts_comment": "accounts 为 mmth 账号名（需与 mmth 下拉菜单显示一致）",
  "_log_path_comment": "log_path 可以是文件路径或目录路径，为目录时将遍历处理目录下所有 .log 文件",
  "_cron_comment": "Cron 表达式格式: 秒 分 时 日 月 周（6字段，秒可为0）",
  "_cron_examples": {
    "每天2点和14点": "0 0 2,14 * * *",
    "每天凌晨1点": "0 0 1 * * *",
    "每30秒": "*/30 * * * * *",
    "每分钟": "0 * * * * *"
  },
  "port": "5391",
  "cron_scrape": "0 0 2,14 * * *",
  "cron_etl": "0 0 1 * * *",
  "mmth_servers": [
    {
      "_comment": "服务器1配置",
      "name": "server1",
      "base_url": "http://YOUR_SERVER_IP:PORT",
      "accounts": ["account1", "account2"],
      "log_path": "./data/logs/server1.log"
    },
    {
      "_comment": "服务器2配置（可选）",
      "name": "server2",
      "base_url": "http://YOUR_SERVER_IP:PORT",
      "accounts": ["account3"],
      "log_path": "./data/logs/server2"
    }
  ],
  "_data_dir": "./data",
  "_etl_binary_path": "./mmth-etl/mmth_etl.exe",
  "_etl_output_dir": "./data/etl"
}
